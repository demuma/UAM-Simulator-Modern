{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Configure Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"build",
				"-DCMAKE_BUILD_TYPE=Debug",
				"-DCMAKE_PREFIX_PATH=/opt/homebrew/opt"
			]
		},
		{
			"label": "Build Debug",
			"type": "shell",
			"dependsOn": "Configure Debug",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--parallel"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"label": "Configure Release",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"build",
				"-DCMAKE_BUILD_TYPE=Release",
				"-DCMAKE_PREFIX_PATH=/opt/homebrew/opt"
			]
		},
		{
			"label": "Build Release",
			"type": "shell",
			"dependsOn": "Configure Release",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--parallel"
			],
			"group": "build"
		},
		{
			"type": "cppbuild",
			"label": "C/C++: clang++ build active file",
			"command": "/usr/bin/clang++",
			"args": [
				"-fcolor-diagnostics",
				"-fansi-escape-codes",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Task generated by Debugger."
		},
		{
			"label": "Convert Surface Tile",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/convert_surface_tile.py"
			],
			"isBackground": false
		},
		{
			"label": "Extract HH Clip",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/extract_clip.py",
				"--full-tile"
			],
			"isBackground": false
		},
		{
			"label": "Build Current",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--parallel"
			],
			"isBackground": false
		},
		{
			"label": "Reconvert Surface Tile",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/convert_surface_tile.py"
			],
			"isBackground": false
		},
		{
			"label": "Extract Ground Mesh",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/extract_ground_mesh.py"
			],
			"isBackground": false
		},
		{
			"label": "Extract Ground Mesh 2",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/extract_ground_mesh.py"
			],
			"isBackground": false
		},
		{
			"label": "Build After Ground Mesh",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--parallel"
			],
			"isBackground": false
		},
		{
			"label": "Reconvert Surface Tile Clipped",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/convert_surface_tile.py"
			],
			"isBackground": false
		},
		{
			"label": "Extract Ground Mesh After Clip",
			"type": "shell",
			"command": "./.venv/bin/python",
			"args": [
				"map/extract_ground_mesh.py"
			],
			"isBackground": false
		}
	]
}